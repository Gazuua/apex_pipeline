CompileFlags:
  Add:
    - --target=x86_64-pc-windows-msvc
    - -std=c++23
    - -Wno-unknown-attributes
    # -external:I 플래그가 Remove로 제거되므로, 동일 경로를 -I로 재추가
    - -ID:/.workspace/vcpkg_installed/x64-windows/include
    - -ID:/.workspace/vcpkg_installed/x64-windows/include/server
  Remove:
    # MSVC C++ standard flag (clangd doesn't understand this)
    - -std:c++latest
    - /std:c++latest
    # MSVC-specific flags incompatible with clangd
    - /EHsc
    - /Zi
    - /Ob0
    - /Od
    - /O2
    - /RTC1
    - /nologo
    - /TP
    - /FS
    - /utf-8
    - /DWIN32
    - /D_WINDOWS
    - -MDd
    - -MD
    - /Fo*
    - /Fd*
    - -external:W0
    - -external:I*
Diagnostics:
  ClangTidy:
    Add:
      - bugprone-*
      - clang-analyzer-*
      - cppcoreguidelines-*
      - performance-*
      - readability-implicit-bool-conversion
      - misc-unused-using-decls
      - modernize-use-nullptr
    Remove:
      - bugprone-easily-swappable-parameters
      - cppcoreguidelines-avoid-magic-numbers
      - cppcoreguidelines-pro-bounds-pointer-arithmetic
      - cppcoreguidelines-pro-type-reinterpret-cast
  UnusedIncludes: Strict
