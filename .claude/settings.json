{
  "extraKnownMarketplaces": {
    "apex-local": {
      "source": {
        "source": "directory",
        "path": "./apex_tools"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./apex_tools/apex-agent/apex-agent hook validate-build",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "./apex_tools/apex-agent/apex-agent hook validate-merge",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "./apex_tools/apex-agent/apex-agent hook validate-handoff",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./apex_tools/apex-agent/apex-agent hook enforce-rebase",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./apex_tools/apex-agent/apex-agent hook handoff-probe",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./apex_tools/setup-claude-plugin.sh",
            "timeout": 10,
            "statusMessage": "auto-review 플러그인 확인 중..."
          },
          {
            "type": "command",
            "command": "bash ./apex_tools/session-context.sh",
            "timeout": 10,
            "statusMessage": "프로젝트 컨텍스트 로딩..."
          }
        ]
      }
    ]
  }
}
