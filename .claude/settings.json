{
  "extraKnownMarketplaces": {
    "apex-local": {
      "source": {
        "source": "directory",
        "path": "./apex_tools"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./apex_tools/setup-claude-plugin.sh",
            "timeout": 10,
            "statusMessage": "auto-review 플러그인 확인 중..."
          },
          {
            "type": "command",
            "command": "bash ./apex_tools/session-context.sh",
            "timeout": 10,
            "statusMessage": "프로젝트 컨텍스트 로딩..."
          }
        ]
      }
    ]
  }
}
