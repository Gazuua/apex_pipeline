{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${hostSystemName}/${presetName}",
      "environment": {
        "VCPKG_ROOT": "$penv{VCPKG_ROOT}"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed",
        "APEX_BUILD_VARIANT": "release"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "APEX_BUILD_VARIANT": "debug"
      }
    },
    {
      "name": "asan",
      "displayName": "Debug + AddressSanitizer (Clang/GCC only)",
      "inherits": "debug",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-fsanitize=address -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address",
        "APEX_BUILD_VARIANT": "asan"
      }
    },
    {
      "name": "asan-msvc",
      "displayName": "Debug + AddressSanitizer (MSVC)",
      "inherits": "debug",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "/fsanitize=address",
        "APEX_BUILD_VARIANT": "asan"
      }
    },
    {
      "name": "tsan",
      "displayName": "Debug + ThreadSanitizer (Clang/GCC only)",
      "inherits": "debug",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-fsanitize=thread",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread",
        "APEX_BUILD_VARIANT": "tsan"
      }
    },
    {
      "name": "iouring",
      "displayName": "Debug + io_uring (Linux only)",
      "inherits": "debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "APEX_USE_IO_URING": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "release", "configurePreset": "release" },
    { "name": "debug", "configurePreset": "debug" },
    { "name": "asan", "configurePreset": "asan" },
    { "name": "asan-msvc", "configurePreset": "asan-msvc" },
    { "name": "tsan", "configurePreset": "tsan" },
    { "name": "iouring", "configurePreset": "iouring" }
  ],
  "testPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "output": { "outputOnFailure": true },
      "environment": {
        "ASAN_OPTIONS": "detect_leaks=1:halt_on_error=1",
        "LSAN_OPTIONS": "suppressions=${sourceDir}/lsan_suppressions.txt"
      }
    },
    {
      "name": "asan-msvc",
      "configurePreset": "asan-msvc",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "tsan",
      "configurePreset": "tsan",
      "output": { "outputOnFailure": true },
      "environment": {
        "TSAN_OPTIONS": "suppressions=${sourceDir}/tsan_suppressions.txt halt_on_error=1"
      }
    },
    {
      "name": "iouring",
      "configurePreset": "iouring",
      "output": { "outputOnFailure": true }
    }
  ]
}
